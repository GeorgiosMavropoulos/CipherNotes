@using Cipher_Notes.Core.Services
@using Cipher_Notes.ViewModels
@using Cipher_Notes.Core.Models
@using Cipher_Notes.Core.Exceptions
@using Cipher_Notes.Core.Interfaces
@using Cipher_Notes.Services
@page "/create"
@inject INoteService NoteService
@inject NavigationManager Navigation
@inject IDialogService DialogService




<div class="container">
    <div class="header">
        <button class="back-btn" @onclick="GoBack">← Back</button>
        <h1>New Note</h1>
    </div>

    <div class="form-group">
        <label>TITLE</label>
        <input type="text" placeholder="Note title..." @bind="title" />
    </div>

    <div class="form-group">
        <label>CONTENT</label>
        <textarea placeholder="Write your note here..." @bind="content"></textarea>
    </div>

    <div class="password-section">
        <label>🔒 ENCRYPTION PASSWORD</label>
        <input type="password" placeholder="Set encryption password" @bind="password" />
        <input type="password" placeholder="Confirm password" @bind="confirmPassword" />
        <small>This password encrypts your note. It cannot be recovered if lost.</small>
    </div>

    <div class="buttons">
        <button class="cancel-btn" @onclick="GoBack">Cancel</button>
        <button class="save-btn" @onclick="SaveNote">Encrypt & Save</button>
    </div>
</div>

@code {
    private string title = "";
    private string content = "";
    private string password = "";
    private string confirmPassword = "";

    private async Task SaveNote()
    {

        //try-catch to handle errors
        try
        {
            //if confirm password is null return an error message
            if(string.IsNullOrEmpty(confirmPassword))
            {
                await DialogService.ShowAlert("Confirmation Error", "Please confirm password", "OK");
                return;
            }
            //validate that password match
                if (await PasswordsMatch())
                {
                    //create note
                    await NoteService.CreateNote(title, content, password);

                    //alert user that note has been created
                await DialogService.ShowAlert("Success", "Note created!", "BACK");
                    Navigation.NavigateTo("/");
                }
                else
                {
                await DialogService.ShowAlert("Error", "Passwords do not match", "OK");
                }


            
        }

        catch (ValidationException ex) //return an error message if password is null
        {
            await DialogService.ShowAlert("Error", ex.Message, "OK"); //return an exception if password, content or title is null
            return;
        }

        catch (Exception ex) //throw a general exception message if sth goes wrong
        {
            await DialogService.ShowAlert("Error", ex.Message, "OK");
        }


    }



    //method to validate that passwords match
    private async Task<bool> PasswordsMatch()
    {
        if (password != confirmPassword) //return an error if passwords do not match
        {
            
            return false;
        }
        return true;
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/");
    }
}