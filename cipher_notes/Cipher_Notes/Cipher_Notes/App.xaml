<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Cipher_Notes"
             x:Class="Cipher_Notes.App">
    <Application.Resources>
        <ResourceDictionary>

            <Color x:Key="PageBackground">#020B1C</Color>
            <Color x:Key="CardBackground">#101827</Color>
            <Color x:Key="AccentColor">#14C8B8</Color>
            <Color x:Key="ButtonColor">#0FA392</Color>
            <Color x:Key="PrimaryText">#FFFFFF</Color>
            <Color x:Key="SecondaryText">#8FA1B8</Color>
            <Color x:Key="BorderColor">#1E2A3C</Color>

        </ResourceDictionary>
    </Application.Resources>
</Application>
